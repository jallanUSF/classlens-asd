# Model provider: openrouter | google | ollama
MODEL_PROVIDER=openrouter
MODEL_NAME=google/gemma-4-27b-it

# OpenRouter (recommended — single key, routes to Gemma 4)
OPENROUTER_API_KEY=your_key_here

# Google AI Studio (alternative — direct access)
GOOGLE_AI_STUDIO_KEY=optional_direct_key

# Ollama (local — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
