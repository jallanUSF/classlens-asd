# Model provider: google (default), openrouter, ollama
MODEL_PROVIDER=google

# Google AI Studio (required when MODEL_PROVIDER=google)
GOOGLE_AI_STUDIO_KEY=your_api_key_here

# OpenRouter (required when MODEL_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-3-27b-it

# Ollama (used when MODEL_PROVIDER=ollama)
OLLAMA_MODEL=gemma3:27b
OLLAMA_BASE_URL=http://localhost:11434/v1
